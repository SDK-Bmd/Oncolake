# Copier vers .env et ajuster. Toutes les vars sont prefixees ONCOLAKE_.
ONCOLAKE_MINIO_ENDPOINT=localhost:9000
ONCOLAKE_MINIO_ACCESS_KEY=minioadmin
ONCOLAKE_MINIO_SECRET_KEY=minioadmin
ONCOLAKE_MINIO_SECURE=false
ONCOLAKE_RAW_BUCKET=oncolake-raw
ONCOLAKE_STAGING_BUCKET=oncolake-staging
ONCOLAKE_DUCKDB_PATH=data/curated.duckdb
